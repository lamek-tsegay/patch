# NIM / Brev — fill in once the Brev instance is provisioned
NIM_ENDPOINT=https://your-brev-instance.brev.dev/v1
NIM_API_KEY=replace-me

# Model IDs (override only if Brev exposes different names)
NIM_MODEL_SUPER=nvidia/nemotron-super-120b
NIM_MODEL_NANO=nvidia/nemotron-nano-30b

# Local findings store
DATABASE_URL=sqlite:///patch.db

# Path to the seeded demo repo the agent scans
DEMO_REPO_PATH=./demo-repo

LOG_LEVEL=INFO
